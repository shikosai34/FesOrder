{
  "name": "new-modern-app",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "hono": "^4.8.2",
      "@trpc/server": "^11.5.0",
      "better-auth": "^1.4.5",
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
